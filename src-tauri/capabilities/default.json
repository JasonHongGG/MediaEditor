{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "export"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:default"
  ]
}